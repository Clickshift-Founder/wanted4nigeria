# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Airtable Personal Access Token
# Get from: airtable.com/create/tokens
AIRTABLE_PAT=your_personal_access_token_here

# Airtable Base ID (starts with app...)
# Get from the URL of your base: airtable.com/appXXXXXXXXX/...
AIRTABLE_BASE_ID=your_base_id_here

# Table names (exact, case-sensitive)
# Defaults shown below — only change if your tables have different names
AIRTABLE_TABLE_NOMINATE_SOMEONE=Nominate someone
AIRTABLE_TABLE_NOMINATE_SELF=Nominate yourself
AIRTABLE_TABLE_APPLICATIONS=Applications
